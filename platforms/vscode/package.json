{
  "name": "pindouverse",
  "displayName": "PindouVerse - Bead Art Editor",
  "description": "PindouVerse (拼豆宇宙) — Open and edit .pindou bead art projects inside VS Code. Pixel art editor for perler/fuse bead designs with 295-color MARD palette, multi-layer support, grid overlay, and blueprint mode.",
  "version": "0.6.1",
  "publisher": "PindouVerse",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cangelzz/pindouverse.git"
  },
  "homepage": "https://github.com/cangelzz/pindouverse",
  "bugs": {
    "url": "https://github.com/cangelzz/pindouverse/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "icon": "icons/icon.png",
  "categories": [
    "Other",
    "Visualization"
  ],
  "keywords": [
    "perler beads",
    "fuse beads",
    "pixel art",
    "bead art",
    "pindou",
    "拼豆"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "pindouverse.editor",
        "displayName": "PindouVerse Editor",
        "selector": [
          {
            "filenamePattern": "*.pindou"
          }
        ],
        "priority": "default"
      }
    ],
    "commands": [
      {
        "command": "pindouverse.newProject",
        "title": "PindouVerse: New Project"
      },
      {
        "command": "pindouverse.openProject",
        "title": "PindouVerse: Open Project"
      }
    ]
  },
  "scripts": {
    "build": "npm run build:ext && npm run build:webview",
    "build:ext": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "build:webview": "vite build --config webview/vite.config.ts",
    "watch": "concurrently \"npm run watch:ext\" \"npm run watch:webview\"",
    "watch:ext": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --watch",
    "watch:webview": "vite build --config webview/vite.config.ts --watch",
    "package": "vsce package",
    "publish:pat": "npm run build && npm run package && vsce publish",
    "publish:entra": "npm run build && npm run package && node scripts/publish-entra.js",
    "test": "npx playwright test"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "latest",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/vscode": "^1.85.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^8.2.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.0"
  }
}
